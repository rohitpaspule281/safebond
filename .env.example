APP_NAME=Safebond API
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
LOG_FORMAT=json
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+asyncpg://safebond:safebond@localhost:5432/safebond
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_AUTO_CREATE_TABLES=true

VECTOR_STORE_PROVIDER=chroma
CHROMA_MODE=local
CHROMA_PERSIST_DIRECTORY=./chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_PREFIX=safebond

GROQ_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

EMOTION_MODEL_NAME=j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment
EMOTION_DEVICE_PREFERENCE=auto
EMOTION_MAX_LENGTH=256
SENTIMENT_MAX_LENGTH=256
EMOTION_CACHE_TTL_SECONDS=1800
EMOTION_CACHE_MAX_SIZE=512
EMOTION_TEXT_HARD_LIMIT=4000
EMOTION_MAX_EXPLANATION_SEGMENTS=3
HF_LOCAL_FILES_ONLY=false
TORCH_NUM_THREADS=
MEMORY_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE_PREFERENCE=auto
MEMORY_CHUNK_SIZE_CHARS=420
MEMORY_CHUNK_OVERLAP_SENTENCES=1
MEMORY_TEXT_HARD_LIMIT=8000
MEMORY_CANDIDATE_MULTIPLIER=3
MEMORY_SEMANTIC_WEIGHT=0.60
MEMORY_RECENCY_WEIGHT=0.20
MEMORY_IMPORTANCE_WEIGHT=0.15
MEMORY_SAME_CONVERSATION_BOOST=0.05
MEMORY_RECENCY_HALF_LIFE_HOURS=168
MEMORY_INDEX_ASSISTANT_MESSAGES=true
SAFETY_ZERO_SHOT_MODEL_NAME=MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli
SAFETY_DEVICE_PREFERENCE=auto
SAFETY_TEXT_HARD_LIMIT=5000
SAFETY_CACHE_TTL_SECONDS=900
SAFETY_CACHE_MAX_SIZE=512
SAFETY_MODERATE_THRESHOLD=0.35
SAFETY_HIGH_THRESHOLD=0.58
SAFETY_CRITICAL_THRESHOLD=0.78
SAFETY_SELF_HARM_THRESHOLD=0.62
MODEL_WARMUP_ON_STARTUP=true
